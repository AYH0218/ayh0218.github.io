---
interface Props {
  id: string;
  kicker: string;
  title: string;
}

const { id, kicker, title } = Astro.props;
---

<section id={id} class="section-shell py-24 sm:py-32">
  <div class="reveal">
    <p class="font-mono text-sm tracking-widest text-accent">{kicker}</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">{title}</h2>
  </div>
  <div class="mt-12">
    <slot />
  </div>
</section>
